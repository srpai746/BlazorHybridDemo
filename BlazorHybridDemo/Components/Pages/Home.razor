@page "/"

<PageTitle>Blazor Hybrid Demo</PageTitle>

<div class="hero-section">
    <h1>🚀 Blazor Hybrid in .NET MAUI</h1>
    <p class="lead">Native + Web: The Best of Both Worlds</p>
</div>

<div class="welcome-content">
    <div class="intro-card">
        <h3>Welcome to the Demo App!</h3>
        <p>
            This application demonstrates the key features and capabilities of
            <strong>Blazor Hybrid</strong> in .NET MAUI. You'll see how to:
        </p>
        <ul>
            <li>Build web UIs with Razor components</li>
            <li>Access native platform APIs</li>
            <li>Manage application state</li>
            <li>Integrate JavaScript interop</li>
            <li>Use device features like camera and GPS</li>
        </ul>
    </div>

    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-icon">📱</div>
            <h4>Counter</h4>
            <p>Basic Blazor component with state management</p>
            <a href="/counter" class="btn btn-sm btn-primary">Try it →</a>
        </div>

        <div class="feature-card">
            <div class="feature-icon">🔄</div>
            <h4>State Demo</h4>
            <p>Shared state across components with singleton service</p>
            <a href="/statedemo" class="btn btn-sm btn-primary">Try it →</a>
        </div>

        <div class="feature-card">
            <div class="feature-icon">📷</div>
            <h4>Camera</h4>
            <p>Native camera integration with photo capture</p>
            <a href="/camera" class="btn btn-sm btn-primary">Try it →</a>
        </div>

        <div class="feature-card">
            <div class="feature-icon">📍</div>
            <h4>Location</h4>
            <p>Access device GPS and geolocation services</p>
            <a href="/location" class="btn btn-sm btn-primary">Try it →</a>
        </div>

        <div class="feature-card">
            <div class="feature-icon">🔄</div>
            <h4>JS Interop</h4>
            <p>Bidirectional C# and JavaScript communication</p>
            <a href="/jsinterop" class="btn btn-sm btn-primary">Try it →</a>
        </div>

        <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h4>Platform Info</h4>
            <p>Device details, battery, connectivity, and more</p>
            <a href="/platforminfo" class="btn btn-sm btn-primary">Try it →</a>
        </div>
    </div>

    <div class="architecture-overview mt-5">
        <h3>🏗️ How Blazor Hybrid Works</h3>
        <div class="architecture-diagram">
            <div class="arch-layer arch-native">
                <strong>.NET MAUI Application</strong>
                <small>Native iOS/Android/Windows/Mac</small>
            </div>
            <div class="arch-arrow">⬇️</div>
            <div class="arch-layer arch-webview">
                <strong>BlazorWebView Component</strong>
                <small>Hosts Blazor content in native WebView</small>
            </div>
            <div class="arch-arrow">⬇️</div>
            <div class="arch-layer arch-razor">
                <strong>Razor Components (HTML/CSS/C#)</strong>
                <small>Your web-based UI</small>
            </div>
            <div class="arch-arrow">⬍</div>
            <div class="arch-layer arch-platform">
                <strong>Platform APIs</strong>
                <small>Camera • GPS • Storage • Sensors</small>
            </div>
        </div>
    </div>

    <div class="benefits-section mt-5">
        <h3>✨ Why Blazor Hybrid?</h3>
        <div class="benefits-grid">
            <div class="benefit-item">
                <strong>🔄 Code Reuse</strong>
                <p>Share components between web and mobile apps</p>
            </div>
            <div class="benefit-item">
                <strong>🚀 Native Performance</strong>
                <p>Full access to platform APIs and native features</p>
            </div>
            <div class="benefit-item">
                <strong>💻 Single Language</strong>
                <p>C# for both UI and business logic</p>
            </div>
            <div class="benefit-item">
                <strong>🔧 Rich Tooling</strong>
                <p>Visual Studio, Hot Reload, and debugging support</p>
            </div>
            <div class="benefit-item">
                <strong>📱 Cross-Platform</strong>
                <p>iOS, Android, Windows, macOS from one codebase</p>
            </div>
            <div class="benefit-item">
                <strong>💰 Cost Effective</strong>
                <p>One team can build web and mobile apps</p>
            </div>
        </div>
    </div>

    <div class="info-box mt-5">
        <h4>📚 About This Demo</h4>
        <p>
            This demo application is part of the session
            <strong>"Native + Web: Understanding Blazor Hybrid in .NET MAUI"</strong>.
        </p>
        <p>
            Each demo page showcases a specific feature with working code examples,
            explanations, and best practices. Navigate using the menu on the left to
            explore different capabilities.
        </p>
        <p class="mb-0">
            <strong>Tech Stack:</strong> .NET 9.0, MAUI, Blazor Hybrid<br />
            <strong>Platforms:</strong> iOS 14.2+, Android API 24+, Windows, macOS
        </p>
    </div>
</div>

