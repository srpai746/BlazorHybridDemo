@page "/location"
@inject IGeolocation Geolocation

<PageTitle>Location Demo</PageTitle>

<h1>📍 Geolocation Demo</h1>

<p>This demo shows how to access device location using native GPS/location services.</p>

<div class="demo-section">
    <h3>Get Current Location</h3>
    <ButtonControl Text="📍 Get My Location"
                   OnClickCallback="GetLocation"
                   CustomClasss="btn btn-primary"
                   ShowLoading="@isLoading"
                   disabled="@isLoading" />
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        <strong>Error:</strong> @errorMessage
    </div>
}

@if (currentLocation != null)
{
    <div class="location-result mt-4">
        <h4>📌 Current Location:</h4>
        <table class="table table-striped">
            <tbody>
                <tr>
                    <td><strong>Latitude:</strong></td>
                    <td>@currentLocation.Latitude.ToString("F6")°</td>
                </tr>
                <tr>
                    <td><strong>Longitude:</strong></td>
                    <td>@currentLocation.Longitude.ToString("F6")°</td>
                </tr>
                <tr>
                    <td><strong>Altitude:</strong></td>
                    <td>@((currentLocation.Altitude?.ToString("F2") ?? "N/A")) meters</td>
                </tr>
                <tr>
                    <td><strong>Accuracy:</strong></td>
                    <td>@((currentLocation.Accuracy?.ToString("F2") ?? "N/A")) meters</td>
                </tr>
                <tr>
                    <td><strong>Speed:</strong></td>
                    <td>@((currentLocation.Speed?.ToString("F2") ?? "N/A")) m/s</td>
                </tr>
                <tr>
                    <td><strong>Timestamp:</strong></td>
                    <td>@currentLocation.Timestamp.ToLocalTime().ToString("g")</td>
                </tr>
            </tbody>
        </table>

        <div class="map-link mt-3">
            <a href="@GetGoogleMapsUrl()" target="_blank" class="btn btn-success">
                🗺️ View on Google Maps
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mt-3">
        No location data yet. Click the button above to get your current location.
    </div>
}

<div class="info-box mt-4">
    <h4>💡 How It Works</h4>
    <ul>
        <li><strong>Native API:</strong> Uses .NET MAUI's <code>IGeolocation</code> interface</li>
        <li><strong>Platform Services:</strong> iOS CoreLocation / Android Location Services</li>
        <li><strong>Permissions:</strong> App requests location permissions at runtime</li>
        <li><strong>Accuracy Levels:</strong> Best, Medium, Low, Default</li>
        <li><strong>Background Location:</strong> Can be configured for continuous tracking</li>
    </ul>

    <h5 class="mt-3">Code Example:</h5>
    <pre><code>var request = new GeolocationRequest(
    GeolocationAccuracy.Medium,
    TimeSpan.FromSeconds(10));

var location = await Geolocation.GetLocationAsync(request);</code></pre>
</div>

@code {
    private Location? currentLocation;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task GetLocation()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            StateHasChanged();

            // Check and request location permission
            var locationStatus = await Permissions.CheckStatusAsync<Permissions.LocationWhenInUse>();
            if (locationStatus != PermissionStatus.Granted)
            {
                locationStatus = await Permissions.RequestAsync<Permissions.LocationWhenInUse>();
            }

            if (locationStatus != PermissionStatus.Granted)
            {
                errorMessage = "Location permission is required. Please grant permission in your device settings.";
                return;
            }

            var request = new GeolocationRequest(
                GeolocationAccuracy.Medium,
                TimeSpan.FromSeconds(10));

            currentLocation = await Geolocation.GetLocationAsync(request);

            if (currentLocation == null)
            {
                errorMessage = "Unable to get location. Please try again.";
            }
        }
        catch (FeatureNotSupportedException)
        {
            errorMessage = "Geolocation is not supported on this device.";
        }
        catch (FeatureNotEnabledException)
        {
            errorMessage = "Location services are disabled. Please enable location services in settings.";
        }
        catch (PermissionException)
        {
            errorMessage = "Permission to access location was denied. Please enable location access in settings.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error getting location: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetGoogleMapsUrl()
    {
        if (currentLocation == null)
            return "#";

        return $"https://www.google.com/maps?q={currentLocation.Latitude},{currentLocation.Longitude}";
    }
}

<style>
    .demo-section {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        margin: 1rem 0;
    }

    .location-result {
        padding: 1rem;
        background: white;
        border: 2px solid #dee2e6;
        border-radius: 8px;
    }

    .info-box {
        padding: 1rem;
        background: #e7f3ff;
        border-left: 4px solid #0066cc;
        border-radius: 4px;
    }

    .info-box ul {
        margin: 0.5rem 0 0 0;
    }

    .info-box code {
        background: #fff;
        padding: 2px 6px;
        border-radius: 3px;
        color: #d63384;
    }

    .info-box pre {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
    }

    .info-box pre code {
        background: transparent;
        padding: 0;
        color: #212529;
    }

    .map-link {
        text-align: center;
    }
</style>
