        padding: 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 8px;
        margin: 1rem 0;
    }

    .state-display {
        background: white;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
    }

    .state-card {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 4px;
    }

